<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle"><string>Menipy ADSA</string></property>

  <!-- Menu bar -->
  <widget class="QMenuBar" name="menubar">
   <property name="nativeMenuBar"><bool>false</bool></property>
   <widget class="QMenu" name="menuFile">
   <property name="title"><string>&amp;File</string></property>
   <addaction name="actionOpenImage"/>
   <addaction name="actionOpenCamera"/>
    <addaction name="actionExportCsv"/>
   <addaction name="separator"/>
   <addaction name="actionQuit"/>
   </widget>
   <widget class="QMenu" name="menuConfig">
    <property name="title"><string>&amp;Config</string></property>
    <addaction name="actionConfigOverlay"/>
    <addaction name="actionConfigMarkers"/>
    <addaction name="separator"/>
    <addaction name="actionConfigPipeline"/>
    <addaction name="separator"/>
    <addaction name="actionConfigPreprocessing"/>
    <addaction name="actionConfigEdgeDetection"/>
    <addaction name="actionConfigGeometry"/>
    <addaction name="actionConfigPhysics"/>
    <addaction name="actionConfigAcquisition"/>
   </widget>
   <widget class="QMenu" name="menuView">
   <property name="title"><string>&amp;View</string></property>
    <!-- You can add pane toggles or dock toggles here in code -->
    <addaction name="actionOverlay"/>
    <addaction name="separator"/>
    <addaction name="actionToggleSetup"/>
    <addaction name="actionToggleResultsTable"/>
    <addaction name="actionToggleKeyResults"/>
    <addaction name="separator"/>
    <addaction name="actionResetLayout"/>
    <addaction name="actionFitPreview"/>
   </widget>
   <widget class="QMenu" name="menuRun">
   <property name="title"><string>&amp;Run</string></property>
    <addaction name="actionPreview"/>
   <addaction name="actionRunFull"/>
   <addaction name="actionRunSelected"/>
    <addaction name="separator"/>
    <addaction name="actionStop"/>
   </widget>
   <widget class="QMenu" name="menuPlugins">
    <property name="title"><string>&amp;Plugins</string></property>
   </widget>
   <widget class="QMenu" name="menuHelp">
    <property name="title"><string>&amp;Help</string></property>
    <addaction name="actionAbout"/>
   </widget>
   <addaction name="menuFile"/>
   <addaction name="menuConfig"/>
   <addaction name="menuView"/>
   <addaction name="menuRun"/>
   <addaction name="menuPlugins"/>
   <addaction name="menuHelp"/>
  </widget>

  <!-- Central area: workbench splitter -->
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="centralLayout">
    <item>
     <widget class="QWidget" name="workflowBar">
      <property name="sizePolicy">
       <sizepolicy hsizetype="Preferred" vsizetype="Fixed">
        <horstretch>0</horstretch>
        <verstretch>0</verstretch>
       </sizepolicy>
      </property>
      <property name="maximumSize">
       <size>
        <width>16777215</width>
        <height>48</height>
       </size>
      </property>
      <layout class="QHBoxLayout" name="workflowBarLayout">
       <property name="leftMargin"><number>12</number></property>
       <property name="topMargin"><number>8</number></property>
       <property name="rightMargin"><number>12</number></property>
       <property name="bottomMargin"><number>8</number></property>
       <property name="spacing"><number>8</number></property>
       <item>
        <widget class="QToolButton" name="toggleSetupBtn">
         <property name="toolTip"><string>Toggle setup rail</string></property>
         <property name="text"><string>Setup</string></property>
         <property name="checkable"><bool>true</bool></property>
         <property name="checked"><bool>true</bool></property>
         <property name="autoRaise"><bool>true</bool></property>
        </widget>
       </item>
       <item>
        <widget class="QToolButton" name="toggleInspectBtn">
         <property name="toolTip"><string>Toggle results table</string></property>
         <property name="text"><string>Table</string></property>
         <property name="checkable"><bool>true</bool></property>
         <property name="checked"><bool>true</bool></property>
         <property name="autoRaise"><bool>true</bool></property>
        </widget>
       </item>
       <item>
        <widget class="QToolButton" name="toggleKeyResultsBtn">
         <property name="toolTip"><string>Toggle key results panel</string></property>
         <property name="text"><string>Results</string></property>
         <property name="checkable"><bool>true</bool></property>
         <property name="checked"><bool>true</bool></property>
         <property name="autoRaise"><bool>true</bool></property>
        </widget>
       </item>
       <item>
        <widget class="QToolButton" name="actionOpenImageBtn">
         <property name="text"><string>Open Image</string></property>
         <property name="toolTip"><string>Load a single image into the active analysis</string></property>
         <property name="autoRaise"><bool>true</bool></property>
        </widget>
       </item>
       <item>
        <widget class="QToolButton" name="actionExportCsvBtn">
         <property name="text"><string>Export CSV</string></property>
         <property name="toolTip"><string>Export the visible results table to CSV</string></property>
         <property name="autoRaise"><bool>true</bool></property>
        </widget>
       </item>
       <item>
       <widget class="QToolButton" name="workflowAdvancedBtn">
         <property name="text"><string>Advanced</string></property>
         <property name="toolTip"><string>Open SOP and pipeline stage controls</string></property>
         <property name="checkable"><bool>false</bool></property>
         <property name="autoRaise"><bool>true</bool></property>
        </widget>
       </item>
       <item>
        <spacer name="workflowSpacer">
         <property name="orientation"><enum>Qt::Horizontal</enum></property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>40</width>
           <height>20</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QSplitter" name="rootSplitter">
      <property name="orientation"><enum>Qt::Horizontal</enum></property>

      <!-- Left: Setup host -->
      <widget class="QWidget" name="setupHost">
       <layout class="QVBoxLayout" name="setupHostLayout"/>
      </widget>

      <!-- Right workbench: preview plus key results above full results/diagnostics -->
      <widget class="QWidget" name="workbenchHost">
       <layout class="QVBoxLayout" name="workbenchHostLayout">
        <property name="leftMargin"><number>0</number></property>
        <property name="topMargin"><number>0</number></property>
        <property name="rightMargin"><number>0</number></property>
        <property name="bottomMargin"><number>0</number></property>
        <item>
         <widget class="QSplitter" name="workbenchSplitter">
          <property name="orientation"><enum>Qt::Vertical</enum></property>
          <widget class="QSplitter" name="previewResultsSplitter">
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <widget class="QWidget" name="previewHost">
            <layout class="QVBoxLayout" name="previewHostLayout"/>
           </widget>
           <widget class="QWidget" name="keyResultsHost">
            <property name="minimumSize">
             <size>
              <width>260</width>
              <height>0</height>
             </size>
            </property>
            <property name="maximumSize">
             <size>
              <width>340</width>
              <height>16777215</height>
             </size>
            </property>
            <layout class="QVBoxLayout" name="keyResultsHostLayout">
             <property name="leftMargin"><number>8</number></property>
             <property name="topMargin"><number>8</number></property>
             <property name="rightMargin"><number>8</number></property>
             <property name="bottomMargin"><number>8</number></property>
            </layout>
           </widget>
          </widget>
          <widget class="QTabWidget" name="inspectTabs">
           <property name="tabPosition"><enum>QTabWidget::North</enum></property>
           <widget class="QWidget" name="resultsTab">
            <attribute name="title"><string>Results</string></attribute>
            <layout class="QVBoxLayout" name="resultsHostLayout"/>
           </widget>
           <widget class="QWidget" name="residualsTab">
            <attribute name="title"><string>Residuals</string></attribute>
            <layout class="QVBoxLayout" name="residualsHostLayout"/>
           </widget>
           <widget class="QWidget" name="timingsTab">
            <attribute name="title"><string>Timings</string></attribute>
            <layout class="QVBoxLayout" name="timingsHostLayout"/>
           </widget>
           <widget class="QWidget" name="logTab">
            <attribute name="title"><string>Log</string></attribute>
            <layout class="QVBoxLayout" name="logHostLayout"/>
           </widget>
          </widget>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>

  <!-- Status bar -->
  <widget class="QStatusBar" name="statusbar"/>

